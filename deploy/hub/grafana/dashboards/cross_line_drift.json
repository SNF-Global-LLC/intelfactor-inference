{
  "dashboard": {
    "title": "IntelFactor — Cross-Line Parameter Drift",
    "uid": "intelfactor-drift",
    "tags": ["intelfactor", "drift"],
    "timezone": "browser",
    "refresh": "1m",
    "time": { "from": "now-7d", "to": "now" },
    "panels": [
      {
        "title": "Parameter Drift Across Stations (7-Day)",
        "type": "timeseries",
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
        "datasource": { "type": "postgres" },
        "targets": [
          {
            "rawSql": "SELECT date_trunc('hour', ct.timestamp) AS time, ct.station_id || ' / ' || ct.cause_parameter AS metric, AVG(ct.cause_drift_pct) AS drift_pct FROM causal_triples ct WHERE ct.timestamp >= $__timeFrom() AND ct.cause_parameter != '' GROUP BY 1, 2 ORDER BY 1",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": { "lineWidth": 2, "fillOpacity": 5, "thresholdsStyle": { "mode": "line" } },
            "thresholds": { "steps": [{"value": -5, "color": "red"}, {"value": -2, "color": "yellow"}, {"value": 0, "color": "green"}, {"value": 2, "color": "yellow"}, {"value": 5, "color": "red"}] }
          }
        }
      },
      {
        "title": "Current Drift by Parameter",
        "type": "table",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
        "datasource": { "type": "postgres" },
        "targets": [
          {
            "rawSql": "SELECT station_id, cause_parameter AS parameter, ROUND(AVG(cause_value)::numeric, 2) AS current_avg, ROUND(AVG(cause_target)::numeric, 2) AS target, ROUND(AVG(cause_drift_pct)::numeric, 1) AS drift_pct, COUNT(*) AS events FROM causal_triples WHERE timestamp >= NOW() - INTERVAL '24 hours' AND cause_parameter != '' GROUP BY station_id, cause_parameter ORDER BY ABS(AVG(cause_drift_pct)) DESC",
            "format": "table"
          }
        ]
      },
      {
        "title": "Parameters Out of Tolerance",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 10 },
        "datasource": { "type": "postgres" },
        "targets": [
          {
            "rawSql": "SELECT COUNT(DISTINCT cause_parameter) FROM causal_triples WHERE timestamp >= NOW() - INTERVAL '24 hours' AND ABS(cause_drift_pct) > 5",
            "format": "table"
          }
        ],
        "fieldConfig": { "defaults": { "thresholds": { "steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "yellow"}, {"value": 3, "color": "red"}] } } }
      },
      {
        "title": "Stations with Drift Issues",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 10 },
        "datasource": { "type": "postgres" },
        "targets": [
          {
            "rawSql": "SELECT COUNT(DISTINCT station_id) FROM causal_triples WHERE timestamp >= NOW() - INTERVAL '24 hours' AND ABS(cause_drift_pct) > 5",
            "format": "table"
          }
        ],
        "fieldConfig": { "defaults": { "thresholds": { "steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "orange"}, {"value": 2, "color": "red"}] } } }
      }
    ]
  }
}
