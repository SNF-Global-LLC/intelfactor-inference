{
  "dashboard": {
    "title": "IntelFactor — Defect Rate by Station",
    "uid": "intelfactor-defect-rate",
    "tags": ["intelfactor", "quality"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-24h", "to": "now" },
    "panels": [
      {
        "title": "Defect Events / Hour (All Stations)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
        "datasource": { "type": "postgres" },
        "targets": [
          {
            "rawSql": "SELECT date_trunc('hour', timestamp) AS time, station_id, COUNT(*) AS events FROM defect_events WHERE timestamp >= $__timeFrom() AND timestamp <= $__timeTo() GROUP BY 1, 2 ORDER BY 1",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": { "lineWidth": 2, "fillOpacity": 10 }
          }
        }
      },
      {
        "title": "Defect Type Distribution",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "datasource": { "type": "postgres" },
        "targets": [
          {
            "rawSql": "SELECT defect_type, COUNT(*) AS count FROM defect_events WHERE timestamp >= $__timeFrom() GROUP BY defect_type ORDER BY count DESC LIMIT 13",
            "format": "table"
          }
        ]
      },
      {
        "title": "Defect Rate by Station (Table)",
        "type": "table",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "datasource": { "type": "postgres" },
        "targets": [
          {
            "rawSql": "SELECT station_id, defect_type, COUNT(*) as total, ROUND(AVG(confidence)::numeric, 2) as avg_confidence FROM defect_events WHERE timestamp >= $__timeFrom() GROUP BY station_id, defect_type ORDER BY total DESC",
            "format": "table"
          }
        ]
      },
      {
        "title": "Hourly Event Count",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
        "datasource": { "type": "postgres" },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) FROM defect_events WHERE timestamp >= NOW() - INTERVAL '1 hour'",
            "format": "table"
          }
        ],
        "fieldConfig": { "defaults": { "thresholds": { "steps": [{"value": 0, "color": "green"}, {"value": 50, "color": "yellow"}, {"value": 100, "color": "red"}] } } }
      },
      {
        "title": "Active Stations",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
        "datasource": { "type": "postgres" },
        "targets": [
          {
            "rawSql": "SELECT COUNT(DISTINCT station_id) FROM defect_events WHERE timestamp >= NOW() - INTERVAL '1 hour'",
            "format": "table"
          }
        ]
      }
    ]
  }
}
