# IntelFactor.ai — Hybrid Environment Variables
# Copy to .env and customize for your deployment.

# Station identification
STATION_ID=station_01

# Camera source
CAMERA_URI=/dev/video0
# CAMERA_URI=rtsp://192.168.1.100:554/stream

# Model files location on host
MODELS_DIR=/opt/intelfactor/models

# Evidence storage limit (GB)
EVIDENCE_MAX_GB=50

# ── Cloud Sync Configuration ────────────────────────────────────────

# Cloud API endpoint
CLOUD_API_URL=https://api.intelfactor.ai
CLOUD_API_KEY=your_api_key_here

# Sync interval (seconds)
SYNC_INTERVAL_SEC=300

# S3 for evidence upload (optional - leave blank to skip)
S3_BUCKET=intelfactor-evidence
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
