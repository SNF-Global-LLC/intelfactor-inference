# IntelFactor.ai — Edge-Only Environment Variables
# Copy to .env and customize for your deployment.
#
# Usage:
#   cp .env.example .env
#   nano .env
#   docker compose up -d

# ── Station Identity ─────────────────────────────────────────────────────────
STATION_ID=wiko-final-inspection-01

# ── Camera ───────────────────────────────────────────────────────────────────
# Protocol: file | pyspin | usb | rtsp
#   file   — load test images from disk (for dev/validation without hardware)
#   pyspin — FLIR Blackfly S via Spinnaker SDK
#   usb    — USB camera via V4L2 (/dev/video0)
#   rtsp   — IP camera via RTSP stream
CAMERA_PROTOCOL=file
CAMERA_URI=/data/sample_images
# CAMERA_PROTOCOL=pyspin
# CAMERA_URI=25423789
# CAMERA_PROTOCOL=usb
# CAMERA_URI=/dev/video0
# CAMERA_PROTOCOL=rtsp
# CAMERA_URI=rtsp://192.168.1.100:554/stream

# ── Models ───────────────────────────────────────────────────────────────────
# Host directory containing models/ tree (mounted read-only into container)
MODELS_DIR=/opt/intelfactor/models

# Path to TRT engine INSIDE the container (relative to /models mount)
VISION_ENGINE_PATH=/models/vision/yolov8n_fp16.engine

# ── Language Model (RCA explanations) ────────────────────────────────────────
# Set to false to start without LLM — RCA uses statistical fallback instead.
ENABLE_LOCAL_LLM=false
LLM_MODEL_PATH=/models/llm/qwen2.5-3b-instruct-q4_k_m.gguf

# ── Storage ──────────────────────────────────────────────────────────────────
DB_PATH=/data/local.db
EVIDENCE_DIR=/data/evidence

# ── API Server ───────────────────────────────────────────────────────────────
API_PORT=8080

# ── Evidence Retention ───────────────────────────────────────────────────────
# FIFO disk quota for JPEG evidence (GB)
EVIDENCE_MAX_GB=50

# ── Cloud Sync (optional — leave empty for edge-only) ────────────────────────
# CLOUD_API_URL=
# CLOUD_API_KEY=

# ── Network (optional — for HTTPS via nginx) ─────────────────────────────────
# SSL_CERT=/path/to/cert.pem
# SSL_KEY=/path/to/key.pem

# ── Datadog Observability (optional) ─────────────────────────────────────────
# Uncomment and set to enable local Datadog Agent sidecar.
# DD_API_KEY=your_datadog_api_key
# DD_SITE=datadoghq.com
