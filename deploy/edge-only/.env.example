# IntelFactor.ai — Edge-Only Environment Variables
# Copy to .env and customize for your deployment.

# Station identification
STATION_ID=station_01

# Camera source (RTSP URL or device path)
CAMERA_URI=/dev/video0
# CAMERA_URI=rtsp://192.168.1.100:554/stream

# Model files location on host
MODELS_DIR=/opt/intelfactor/models

# Evidence storage limit (GB)
EVIDENCE_MAX_GB=50

# Network (optional - for HTTPS)
# SSL_CERT=/path/to/cert.pem
# SSL_KEY=/path/to/key.pem
