# IntelFactor.ai — Inference Package Environment Variables
# Copy to .env and customize for your deployment.

# ── Storage Mode ────────────────────────────────────────────────────
# Options: local (SQLite), cloud (DynamoDB/Postgres)
STORAGE_MODE=local

# SQLite database path (for local mode)
SQLITE_DB_PATH=/opt/intelfactor/data/local.db

# Evidence directory
EVIDENCE_DIR=/opt/intelfactor/data/evidence

# ── Station Configuration ───────────────────────────────────────────
STATION_ID=station_01

# Camera source (RTSP URL or device path)
CAMERA_URI=/dev/video0
# CAMERA_URI=rtsp://192.168.1.100:554/stream

# ── API Server ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080

# ── Model Paths ─────────────────────────────────────────────────────
VISION_MODEL_PATH=/opt/intelfactor/models/vision
LLM_MODEL_PATH=/opt/intelfactor/models/llm

# ── Evidence Settings ───────────────────────────────────────────────
# Maximum evidence storage in GB (FIFO deletion when exceeded)
EVIDENCE_MAX_GB=50

# JPEG quality (1-100)
EVIDENCE_JPEG_QUALITY=85

# ── Cloud Sync (for hybrid mode) ────────────────────────────────────
# CLOUD_API_URL=https://api.intelfactor.ai
# CLOUD_API_KEY=your_api_key_here
# SYNC_ENABLED=false
# SYNC_INTERVAL_SEC=300
